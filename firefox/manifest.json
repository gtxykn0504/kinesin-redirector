{
  "manifest_version": 3,
  "name": "Kinesin",
  "version": "1.1",
  "description": "URL redirect rules with optional remote sync",
  "permissions": [
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["browser-polyfill.js", "background.js"]
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "@kinesin-redirector",
      "data_collection_permissions": {
        "required": ["browsingActivity"]
      },
      "strict_min_version": "140.0"
    }
  }
}